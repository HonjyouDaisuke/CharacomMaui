<?xml version = "1.0" encoding = "UTF-8" ?>
<ContentPage
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  x:Class="CharacomMaui.Presentation.BasePage"
  xmlns:components="clr-namespace:CharacomMaui.Presentation.Components"
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:panel="clr-namespace:CharacomMaui.Presentation.Panels">

  <ContentPage.ControlTemplate>
    <ControlTemplate>

      <Grid RowDefinitions="*">

        <!-- ここに子ページの中身が入る -->
        <ContentPresenter Grid.Row="0"/>

        <BoxView x:Name="Overlay"
                 Grid.Row="0"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 Opacity="0"/>

        <panel:NotificationsPanel
          x:Name="NotificationPanel"
          Grid.Row="0"
          IsVisible="False"
          HorizontalOptions="End"
          WidthRequest="300"/>
        <!-- ★ SnackBar追加 -->
        <components:SnackBarView
          Grid.Row="0"
          VerticalOptions="End"
          HorizontalOptions="Fill"/>

      </Grid>

    </ControlTemplate>
  </ContentPage.ControlTemplate>

</ContentPage>
